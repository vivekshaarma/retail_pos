# Copy this file to .env and fill in your values
# NEVER commit the real .env file to git

# MongoDB connection string
# Local:  mongodb://localhost:27017/retailos
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/retailos
MONGO_URI=mongodb://localhost:27017/retailos

# Secret key for signing JWT ACCESS tokens (short-lived, 15 min)
JWT_SECRET=replace_this_with_a_long_random_string_abc123xyz

# Secret key for signing JWT REFRESH tokens (long-lived, 30 days)
# Must be a DIFFERENT value from JWT_SECRET
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string_def456

# Port the Express server listens on
PORT=5000

# Frontend URL (for CORS) — change in production
CLIENT_URL=http://localhost:5173
